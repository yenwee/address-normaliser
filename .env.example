GDRIVE_TOKEN_PATH=credentials/token.json
GDRIVE_CLIENT_SECRETS_PATH=credentials/client_secret.json
GDRIVE_UPLOAD_FOLDER_ID=
GDRIVE_PROCESSING_FOLDER_ID=
GDRIVE_COMPLETED_FOLDER_ID=
GDRIVE_ARCHIVE_UPLOAD_FOLDER_ID=
POLL_INTERVAL_SECONDS=30
NOMINATIM_ENABLED=false
CONFIDENCE_THRESHOLD=0.6

# Online validation (no new output columns; logs + optional confidence downgrade)
ONLINE_VALIDATION_ENABLED=false
ONLINE_VALIDATION_MAILABLE_ONLY=true
ONLINE_VALIDATION_REVIEW_NO_RESULT=false
ONLINE_VALIDATION_PROVIDERS=tomtom,geoapify,locationiq
ONLINE_VALIDATION_TIMEOUT_SECONDS=10
TOMTOM_API_KEY=
GEOAPIFY_API_KEY=
LOCATIONIQ_API_KEY=

# Email notifications (leave empty to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CLIENT_EMAIL=
